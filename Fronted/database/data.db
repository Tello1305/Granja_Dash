CREATE DATABASE GranjaDashboard;
USE GranjaDashboard;

CREATE TABLE role (
    id_role INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL
);

CREATE TABLE users (
    id_user INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    username VARCHAR(100) NOT NULL,
    password VARCHAR(100) NOT NULL,
    id_role INT NOT NULL,
    date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_role) REFERENCES role(id_role)
);

CREATE TABLE category_animal (
    id_category INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(200) NOT NULL
);

CREATE TABLE products (
    id_product INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(200) NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    id_category INT NOT NULL,
    photo VARCHAR(200) NOT NULL,
    FOREIGN KEY (id_category) REFERENCES category_animal(id_category)
);

CREATE TABLE animals (
    id_animal INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(200) NOT NULL,
    date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE food (
    id_food INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(200) NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    kilograms INT NOT NULL,
    date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    photo VARCHAR(200) NOT NULL,
    id_category INT NOT NULL,
    FOREIGN KEY (id_category) REFERENCES category_animal(id_category)
);

CREATE TABLE quotes (
    id_quote INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    description VARCHAR(200) NOT NULL,
    date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    id_category INT NOT NULL,
    FOREIGN KEY (id_category) REFERENCES category_animal(id_category)
);

